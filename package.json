{
  "name": "react-native-smart-keyboard-view",
  "version": "1.0.0-beta.1",
  "description": "A modern, TypeScript-native keyboard-aware scroll view for React Native with hooks support",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bob build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jmzp/react-native-smart-keyboard-view"
  },
  "keywords": [
    "react-native",
    "keyboard",
    "scroll-view",
    "keyboard-aware",
    "ios",
    "android",
    "typescript",
    "hooks"
  ],
  "author": "Jorge Zapata <jmzp.dev@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.7.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "react": "^18.3.1",
    "react-native": "^0.74.2",
    "react-native-builder-bob": "^0.21.3",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native)/)"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "semi": false,
    "printWidth": 100
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
